{
  "name": "vscode-extension-boilerplate",
  "displayName": "VS Code Extension Boilerplate",
  "description": "A comprehensive starter template for VS Code extensions",
  "version": "0.1.0",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "extension.helloWorld",
        "title": "Boilerplate: Hello World",
        "category": "Boilerplate"
      },
      {
        "command": "extension.openWebview",
        "title": "Boilerplate: Open Webview Panel",
        "category": "Boilerplate"
      },
      {
        "command": "extension.runBackgroundJob",
        "title": "Boilerplate: Run Background File Job",
        "category": "Boilerplate"
      }
    ],
    "configuration": {
      "title": "Extension Boilerplate",
      "properties": {
        "extension.enableFeature": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable a core feature of the extension."
        },
        "extension.sampleString": {
          "type": "string",
          "default": "default value",
          "description": "A sample string setting for the extension."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "boilerplate-sidebar",
          "title": "Boilerplate View",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "boilerplate-sidebar": [
        {
          "id": "boilerplate-view",
          "name": "Sample Tree View"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "extension.runBackgroundJob",
          "group": "navigation",
          "when": "explorerResourceIsFolder"
        }
      ],
      "commandPalette": [
        {
          "command": "extension.helloWorld",
          "when": "true"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
